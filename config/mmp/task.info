  joint_upper_limits
  {
    (0,0)   1.0472       ; LF_HAA
    (1,0)   3.4907       ; LF_HFE
    (2,0)  -0.8377       ; LF_KFE
    (3,0)   1.0472       ; RF_HAA
    (4,0)   3.4907       ; RF_HFE
    (5,0)  -0.8377     ; RF_KFE
    (6,0)   1.0472       ; LH_HAA
    (7,0)   4.5379     ; LH_HFE
    (8,0)   -0.8377     ; LH_KFE
    (9,0)   1.0472     ; RH_HAA
    (10,0)  4.5379     ; RH_HFE
    (11,0)  -0.8377    ; RH_KFE
  }

  joint_velocity_limits
  {
    (0,0)    30.1       ; LF_HAA
    (1,0)    30.1       ; LF_HFE
    (2,0)    20.06       ; LF_KFE
    (3,0)    30.1       ; RF_HAA
    (4,0)    30.1       ; RF_HFE
    (5,0)    20.06       ; RF_KFE
    (6,0)    30.1       ; LH_HAA
    (7,0)    30.1       ; LH_HFE
    (8,0)    20.06       ; LH_KFE
    (9,0)    30.1       ; RH_HAA
    (10,0)   30.1       ; RH_HFE
    (11,0)   20.06       ; RH_KFE
  }

  joint_torque_limits
  {
    (0,0)   23.7       ; LF_HAA
    (1,0)   23.7       ; LF_HFE
    (2,0)   35.55       ; LF_KFE
    (3,0)   23.7       ; RF_HAA
    (4,0)   23.7       ; RF_HFE
    (5,0)   35.55       ; RF_KFE
    (6,0)   23.7       ; LH_HAA
    (7,0)   23.7       ; LH_HFE
    (8,0)   35.55       ; LH_KFE
    (9,0)   23.7       ; RH_HAA
    (10,0)  23.7       ; RH_HFE
    (11,0)  35.55       ; RH_KFE
  }

  swing_trajectory_settings
  {
    liftOffVelocity               0.2
    touchDownVelocity            -0.4
    swingHeight                   0.08
    touchdownAfterHorizon         0.2
    errorGain                     20.0
    swingTimeScale                0.15
    sdfMidswingMargin             0.0
    terrainMargin                 0.0
