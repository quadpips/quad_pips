terrainPlane
{
  position
  {
    x       0.0;
    y       0.0;
    z       0.0;
  }
  orientation
  {
    roll    0.0;
    pitch   0.0;
    yaw     0.0;
  }
}

defaultModeSequenceTemplate
{
  modeSequence
  {
    [0]  STANCE
  }
  switchingTimes
  {
    [0]  0.0
    [1]  1.0
  }
}

; Rollout settings
rollout
{
  AbsTolODE                       1e-5
  RelTolODE                       1e-3
  timeStep                        0.015
  integratorType                  ODE45
  maxNumStepsPerSecond            10000
  checkNumericalStability         false
}

mpc
{
  timeHorizon                     0.5
  solutionTimeWindow              -1  ; [s]
  coldStart                       false

  debugPrint                      false

  mpcDesiredFrequency             50  ; [Hz]
  mrtDesiredFrequency             400 ; [Hz]
}

